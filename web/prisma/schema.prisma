// Veridity database schema.
// MVP uses SQLite (a file — zero infra). To scale to Postgres later: change
// provider to "postgresql", set DATABASE_URL to your Postgres/Neon URL, and run
// `npx prisma db push`. All Prisma queries below are provider-agnostic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  // null for OAuth-only accounts
  name         String?
  company      String?
  image        String?  // avatar from OAuth provider
  plan         String   @default("free") // free | pro | business
  emailVerified DateTime?              // set when the user confirms their email
  googleId     String?                 // OAuth subject ids (uniqueness enforced in code)
  appleId      String?
  aiProvider   String?                 // preferred default model provider
  aiModel      String?                 // preferred default model id
  forgePattern String?  // dominant founder pattern
  forgeConfidence Int   @default(0) // 0-100
  createdAt    DateTime @default(now())
  sessions     Session[]
  checks       Check[]
  links        VerificationLink[]
  interviews   Interview[]
  forge        ForgeSession[]
  forgeCommitments ForgeCommitment[]
  tokens       VerificationToken[]
  subscription Subscription?
  payments     Payment[]
  trustReports TrustReport[]
  botSessions  InterviewSession[]
  apiKeys      ApiKey[]
  monitors     Monitor[]
  alerts       Alert[]
  webhooks     Webhook[]
  orgId        String?   // team workspace this user belongs to
  orgRole      String?   // owner | member
  ownedOrgs    Organization[] @relation("OrgOwner")

  @@index([googleId])
  @@index([appleId])
  @@index([orgId])
}

// Outbound webhooks — push events to the customer's own systems.
model Webhook {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url        String
  secret     String   // HMAC signing secret (shown once)
  events     String   // comma-separated event names, or "*"
  active     Boolean  @default(true)
  lastStatus Int?     // last delivery HTTP status
  lastAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Team workspace.
model Organization {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  invites   Invite[]
}

model Invite {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email     String
  token     String   @unique
  status    String   @default("pending") // pending | accepted
  createdAt DateTime @default(now())

  @@index([orgId])
}

// High-risk alerts surfaced in the app (and optionally emailed).
model Alert {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateName String?
  band          String   // usually "red"
  source        String   // trust | bulk | monitor | link
  message       String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Developer API keys for the public Trust API (v1). We store only a hash.
model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String   // shown in the UI to identify the key (e.g. thk_live_ab12)
  keyHash    String   @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Live interview bot session — a bot joins the call, transcribes in real time,
// takes notes, verifies the candidate, and produces a scored report.
model InterviewSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateName  String?
  role           String?
  platform       String?  // zoom | meet | teams | manual
  meetingUrl     String?
  botId          String?  // Recall.ai bot id
  status         String   @default("scheduled") // scheduled | joining | in_call | processing | done | failed
  transcript     String   @default("") // appended live
  notes          String?  // running AI notes
  // scored report
  summary        String?
  strengths      String?  // JSON string[]
  concerns       String?  // JSON string[]
  questions      String?  // JSON string[]
  recommendation String?  // Strong Yes | Yes | Maybe | No
  fitScore       Int?
  // interview integrity (proxy / scripted / deepfake signals)
  integrity      String?  // JSON: { flags: {label,status,detail}[] }
  integrityScore Int?     // 0-100 (higher = more trustworthy)
  checkId        String?  // linked deepfake Check on the recording
  trustReportId  String?
  recordingUrl   String?
  model          String?
  createdAt      DateTime @default(now())
  endedAt        DateTime?

  @@index([userId, createdAt])
  @@index([botId])
}

// Candidate Trust Score — fuses the deepfake verdict with metadata signals
// (email, phone, location consistency, résumé authenticity) into one score.
model TrustReport {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateName  String?
  email          String?
  phone          String?
  claimedCountry String?  // ISO-2 country the candidate claims (e.g. US, IN)
  score          Int      // 0-100 overall trust
  band           String   // green | yellow | red
  signals        String   // JSON: Signal[] { key, label, status, detail, weight }
  checkId        String?  // optional linked deepfake Check
  resumeFlag     String?  // AI verdict on résumé authenticity
  model          String?  // AI model used for résumé analysis
  shareToken     String?  // public "TrueHire Verified" share link (random, unique in practice)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([shareToken])
}

// One-time tokens for email verification and password reset.
model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // verify_email | reset_password
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, type])
}

// Subscription mirror — one active row per user (Razorpay or Stripe).
model Subscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   String   // pro | business
  provider               String   @default("razorpay") // razorpay | stripe
  status                 String   @default("created") // created | authenticated | active | pending | halted | cancelled | completed | expired
  razorpaySubscriptionId String?  @unique
  razorpayCustomerId     String?
  stripeSubscriptionId   String?  // indexed; uniqueness enforced in code
  stripeCustomerId       String?
  shortUrl               String?  // hosted checkout / management url
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([stripeSubscriptionId])
}

// Audit log of payment events from Razorpay webhooks.
model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  razorpayPaymentId String?  @unique
  amount            Int      // in paise
  currency          String   @default("INR")
  status            String   // captured | failed | refunded
  description       String?
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

model ForgeSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  decisionContext String?
  mode            String?  // insight | accountability | confrontation | exploration
  category        String?  // people | pricing | priorities | communication | delegation | strategy | execution
  pattern         String?  // detected pattern for this session
  rationale       String?
  insight         String?  // one-sentence close observation
  status          String   @default("active") // active | completed
  clarityScore    Int?     // 0-100
  createdAt       DateTime @default(now())
  closedAt        DateTime?
  messages        ForgeMessage[]
  commitments     ForgeCommitment[]

  @@index([userId, createdAt])
}

model ForgeMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ForgeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user | coach
  content   String
  avoidance Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model ForgeCommitment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?
  session   ForgeSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  text      String   // verbatim
  deadline  String?
  status    String   @default("pending") // pending | done | in_progress | not_done
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Interview {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateName  String?
  role           String?
  transcript     String   // raw interview transcript / notes
  summary        String?
  strengths      String?  // JSON array
  concerns       String?  // JSON array
  questions      String?  // JSON array (suggested follow-ups)
  recommendation String?  // Strong Yes | Yes | Maybe | No
  fitScore       Int?     // 0-100
  model          String?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model VerificationLink {
  id             String   @id @default(cuid())
  token          String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateName  String?
  status         String   @default("pending") // pending | done
  checkId        String?
  // ID + liveness verification
  mode           String   @default("basic") // basic | id
  challengeCode  String?  // shown to the candidate as a liveness prompt
  livenessPassed Boolean  @default(false)
  idChecked      Boolean  @default(false)
  faceMatchScore Int?     // 0-100 selfie↔ID match (null = provider not configured)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

// Continuous / post-hire re-verification — periodically re-screen a hire.
model Monitor {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectName    String?
  email          String?
  phone          String?
  claimedCountry String?
  intervalDays   Int      @default(30)
  status         String   @default("active") // active | paused
  lastRunAt      DateTime?
  nextDueAt      DateTime
  lastScore      Int?
  lastBand       String?
  runs           Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([userId, nextDueAt])
}

// Fraud Intelligence Network — privacy-safe cross-account signal graph.
// We store only SHA-256 hashes of identifiers, never raw PII.
model FraudSignal {
  id         String   @id @default(cuid())
  kind       String   // email | phone | domain
  hash       String   // sha256 of the normalized identifier
  band       String   // green | yellow | red (outcome that was seen)
  reporterId String   // which account observed it (for distinct-account counts)
  createdAt  DateTime @default(now())

  @@index([hash])
  @@index([kind, hash])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Check {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateName String?
  fileName      String
  mediaType     String?
  band          String?  // green | yellow | red
  score         Int?     // 0..100 risk
  rdStatus      String?  // Reality Defender status
  engine        String?  // realitydefender | sample
  signals       String?  // JSON-encoded Signal[]
  status        String   @default("ANALYZING") // ANALYZING | DONE | ERROR
  requestId     String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}
