# Copy this file to ".env" and fill in your values.
#   cp .env.example .env   (or just rename it)

# Get a free API key (50 image/audio scans per month) at:
#   https://app.realitydefender.ai/settings/manage-api-keys
RD_API_KEY=

# Access code for pilots. If set, users must enter this code before they can
# run real detection — stops random visitors from burning your free scans.
# Pick anything; share it only with your pilot users. Leave blank = open.
ACCESS_CODE=

# Safety cap so you never blow past the free tier (50/mo). Detection is blocked
# once this many scans run in a month. Raise it when you upgrade your RD plan.
MAX_MONTHLY_SCANS=45

# Optional — defaults to 3000 (hosting platforms set this automatically).
PORT=3000
